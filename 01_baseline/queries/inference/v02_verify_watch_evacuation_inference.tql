match
  $decision isa evacuation-decision, has alert-level "주의";
  $incident isa fire-incident, has name $incident-name;
  $settlement isa settlement, has name $settlement-name;
  (decision: $decision, incident: $incident) isa evacuation-decision-for-incident;
  (decision: $decision, settlement-role: $settlement) isa evacuation-targets-settlement;
select $incident-name, $settlement-name;
