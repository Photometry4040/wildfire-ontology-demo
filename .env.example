# ─── 공공데이터포털 API 키 ───
# 신청: https://www.data.go.kr/data/15084817/openapi.do
FORESTRY_API_KEY=your_api_key_here

# KMA 기상 API 키
# 신청: https://www.data.go.kr/data/15084084/openapi.do
KMA_API_KEY=your_api_key_here

# ─── LLM API 키 ───
# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Google Gemini
GOOGLE_API_KEY=your_google_key_here

# ─── LM Studio 로컬 LLM (선택) ───
LM_STUDIO_BASE_URL=http://127.0.0.1:1234
LM_STUDIO_MODEL=google/gemma-4-e4b

# ─── TypeDB 접속 정보 (기본값: TypeDB CE 로컬 설치 기준) ───
# TYPEDB_ADDRESS=localhost:1729
# TYPEDB_DB=onto-fire-dol
